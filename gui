import tkinter as tk
from tkinter import ttk, messagebox
import threading
import asyncio
import logging

# Импортируем конфигурацию и главную функцию из вашего скрипта
# ВАЖНО: переименуйте ваш файл main.py в gateway.py во избежание конфликтов,
# либо импортируйте как есть, если имя файла main.py:
import main as gw 

class ConfiguratorApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Настройка OPC UA & Modbus Шлюза")
        self.root.geometry("450x400")
        self.root.resizable(False, False)

        self.gateway_thread = None
        self.loop = None

        self.create_widgets()

    def create_widgets(self):
        # --- Фрейм Modbus ---
        modbus_frame = ttk.LabelFrame(self.root, text="Настройки Modbus (Источник)")
        modbus_frame.pack(fill="x", padx=10, pady=5)

        ttk.Label(modbus_frame, text="IP Адрес:").grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.mb_host_entry = ttk.Entry(modbus_frame)
        self.mb_host_entry.insert(0, gw.CONFIG["modbus"]["host"])
        self.mb_host_entry.grid(row=0, column=1, padx=5, pady=5)

        ttk.Label(modbus_frame, text="Порт:").grid(row=1, column=0, padx=5, pady=5, sticky="e")
        self.mb_port_entry = ttk.Entry(modbus_frame)
        self.mb_port_entry.insert(0, str(gw.CONFIG["modbus"]["port"]))
        self.mb_port_entry.grid(row=1, column=1, padx=5, pady=5)

        # --- Фрейм OPC UA ---
        opc_frame = ttk.LabelFrame(self.root, text="Настройки OPC UA (Сервер)")
        opc_frame.pack(fill="x", padx=10, pady=5)

        ttk.Label(opc_frame, text="Endpoint:").grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.opc_endpoint_entry = ttk.Entry(opc_frame, width=30)
        self.opc_endpoint_entry.insert(0, gw.CONFIG["opcua"]["endpoint"])
        self.opc_endpoint_entry.grid(row=0, column=1, padx=5, pady=5)

        # --- Фрейм API ---
        api_frame = ttk.LabelFrame(self.root, text="Настройки API")
        api_frame.pack(fill="x", padx=10, pady=5)

        ttk.Label(api_frame, text="Порт API:").grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.api_port_entry = ttk.Entry(api_frame)
        self.api_port_entry.insert(0, str(gw.CONFIG["api"]["port"]))
        self.api_port_entry.grid(row=0, column=1, padx=5, pady=5)

        # --- Статус и Кнопки ---
        self.status_label = ttk.Label(self.root, text="Статус: Остановлен", foreground="red", font=("Arial", 10, "bold"))
        self.status_label.pack(pady=10)

        btn_frame = ttk.Frame(self.root)
        btn_frame.pack(pady=5)

        self.btn_start = ttk.Button(btn_frame, text="Запустить шлюз", command=self.start_gateway)
        self.btn_start.pack(side="left", padx=5)

        self.btn_stop = ttk.Button(btn_frame, text="Остановить шлюз", command=self.stop_gateway, state="disabled")
        self.btn_stop.pack(side="left", padx=5)

    def update_config_from_ui(self):
        """Считывает данные из полей и обновляет глобальный словарь CONFIG"""
        try:
            gw.CONFIG["modbus"]["host"] = self.mb_host_entry.get()
            gw.CONFIG["modbus"]["port"] = int(self.mb_port_entry.get())
            gw.CONFIG["opcua"]["endpoint"] = self.opc_endpoint_entry.get()
            gw.CONFIG["api"]["port"] = int(self.api_port_entry.get())
            return True
        except ValueError:
            messagebox.showerror("Ошибка", "Проверьте правильность введенных данных (порты должны быть числами).")
            return False

    def run_async_loop(self):
        """Запуск асинхронного кода в отдельном потоке"""
        self.loop = asyncio.new_event_loop()
        asyncio.set_event_loop(self.loop)
        gw.stop_event.clear() # Сбрасываем флаг остановки
        try:
            self.loop.run_until_complete(gw.main())
        except Exception as e:
            logging.error(f"Сбой шлюза: {e}")
        finally:
            self.loop.close()
            # Возвращаем интерфейс в исходное состояние при падении
            self.root.after(0, self.set_ui_stopped)

    def start_gateway(self):
        if not self.update_config_from_ui():
            return

        self.btn_start.config(state="disabled")
        self.btn_stop.config(state="normal")
        self.status_label.config(text="Статус: В работе", foreground="green")

        # Запускаем шлюз в фоновом потоке
        self.gateway_thread = threading.Thread(target=self.run_async_loop, daemon=True)
        self.gateway_thread.start()

    def stop_gateway(self):
        self.status_label.config(text="Статус: Остановка...", foreground="orange")
        self.btn_stop.config(state="disabled")

        # Даем команду асинхронному циклу на остановку
        if self.loop and self.loop.is_running():
            self.loop.call_soon_threadsafe(gw.stop_event.set)
            # Отменяем все задачи
            for task in asyncio.all_tasks(self.loop):
                self.loop.call_soon_threadsafe(task.cancel)

        self.set_ui_stopped()

    def set_ui_stopped(self):
        self.status_label.config(text="Статус: Остановлен", foreground="red")
        self.btn_start.config(state="normal")
        self.btn_stop.config(state="disabled")

if __name__ == "__main__":
    root = tk.Tk()
    app = ConfiguratorApp(root)
    root.mainloop()
